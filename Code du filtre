  function forceInputTransparent(input) {
    if (!input) return;

    if (input.dataset.ytcwgOrigColor === undefined) {
      const s = getComputedStyle(input);
      input.dataset.ytcwgOrigColor = s.color || '';
      input.dataset.ytcwgOrigFill = s.webkitTextFillColor || '';
      input.dataset.ytcwgOrigCaret = s.caretColor || '';
      input.dataset.ytcwgOrigShadow = s.textShadow || '';
    }

    input.style.color = 'transparent';
    input.style.webkitTextFillColor = 'transparent';
    input.style.textShadow = 'none';
    input.style.caretColor = input.dataset.ytcwgOrigCaret && input.dataset.ytcwgOrigCaret !== 'auto'
