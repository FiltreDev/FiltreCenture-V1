  function syncMirrorScroll() {
    if (!mirrorEl || !currentInput) return;
    mirrorEl.scrollTop = currentInput.scrollTop || 0;
    mirrorEl.scrollLeft = currentInput.scrollLeft || 0;
  }

  function detectMatches(originalText) {
    const { text, map } = normalizeWholeText(originalText);
    const tokens = [];
    const re = /[a-z0-9]+/g;
    let m;

    while ((m = re.exec(text))) {
      const tokenText = m[0];
      const canonical = collapseRepeats(tokenText);
      const normStart = m.index;
      const normEnd = m.index + tokenText.length;
      const origStart = map[normStart] ?? 0;
      const origEnd = (map[normEnd - 1] ?? origStart) + 1;
      tokens.push({ canonical, origStart, origEnd });
    }

    const ranges = [];

    for (const token of tokens) {
      if (compiled.wordSet.has(token.canonical)) {
        ranges.push([token.origStart, token.origEnd]);
      }
    }

    for (const phrase of compiled.phrases) {
      const len = phrase.length;
      for (let i = 0; i <= tokens.length - len; i++) {
        let ok = true;
        for (let j = 0; j < len; j++) {
          if (tokens[i + j].canonical !== phrase[j]) {
            ok = false;
            break;
          }
        }
        if (ok) {
          ranges.push([tokens[i].origStart, tokens[i + len - 1].origEnd]);
        }
      }
    }

    return { ranges: mergeRanges(ranges) };
  }

  function mergeRanges(ranges) {
    if (!ranges.length) return [];
    const sorted = ranges.filter(r => r[1] > r[0]).sort((a, b) => a[0] - b[0]);
    const out = [sorted[0].slice()];

    for (let i = 1; i < sorted.length; i++) {
      const last = out[out.length - 1];
      const cur = sorted[i];
      if (cur[0] <= last[1]) last[1] = Math.max(last[1], cur[1]);
      else out.push(cur.slice());
    }
    return out;
  }

  function renderMirrorOverInput(input, text, ranges) {
    if (!mirrorEl || !input) return;

    const rect = input.getBoundingClientRect();
    const s = getComputedStyle(input);

    mirrorEl.style.left = `${rect.left}px`;
    mirrorEl.style.top = `${rect.top}px`;
    mirrorEl.style.width = `${rect.width}px`;
    mirrorEl.style.height = `${rect.height}px`;
    mirrorEl.style.font = s.font;
    mirrorEl.style.fontFamily = s.fontFamily;
    mirrorEl.style.fontSize = s.fontSize;
    mirrorEl.style.fontWeight = s.fontWeight;
    mirrorEl.style.fontStyle = s.fontStyle;
    mirrorEl.style.letterSpacing = s.letterSpacing;
    mirrorEl.style.lineHeight = s.lineHeight;
    mirrorEl.style.textAlign = s.textAlign;
    mirrorEl.style.direction = s.direction;
    mirrorEl.style.paddingTop = s.paddingTop;
    mirrorEl.style.paddingRight = s.paddingRight;
    mirrorEl.style.paddingBottom = s.paddingBottom;
    mirrorEl.style.paddingLeft = s.paddingLeft;
    mirrorEl.style.borderTopWidth = s.borderTopWidth;
    mirrorEl.style.borderRightWidth = s.borderRightWidth;
    mirrorEl.style.borderBottomWidth = s.borderBottomWidth;
    mirrorEl.style.borderLeftWidth = s.borderLeftWidth;
    mirrorEl.style.boxSizing = s.boxSizing;
    mirrorEl.style.color = input.dataset.ytcwgOrigColor || s.color || '#ffffff';

    mirrorEl.replaceChildren();

    let cursor = 0;
    for (const [start, end] of ranges) {
      if (start > cursor) {
        mirrorEl.appendChild(document.createTextNode(text.slice(cursor, start)));
      }
      const span = document.createElement('span');
      span.className = FLAG_CLASS;
      span.textContent = text.slice(start, end);
      mirrorEl.appendChild(span);
      cursor = end;
    }
    if (cursor < text.length) {
      mirrorEl.appendChild(document.createTextNode(text.slice(cursor)));
    }

    syncMirrorScroll();
  }

  function createButton() {
    if (buttonEl && document.contains(buttonEl)) return;

