  function compileLexicons() {
    const wordSet = new Set();
    const phrases = [];

    for (const word of LEXICONS.words) {
      const canon = canonicalizeWord(word);
      if (canon) wordSet.add(canon);
    }

    for (const phrase of LEXICONS.phrases) {
      const tokens = normalizePhraseToTokens(phrase);
      if (tokens.length) phrases.push(tokens);
    }

    const customBits = (config.customTerms || '')
      .split(/[\n,;]/)
      .map(s => s.trim())
      .filter(Boolean);

    for (const piece of customBits) {
      const tokens = normalizePhraseToTokens(piece);
      if (!tokens.length) continue;
      if (tokens.length === 1) wordSet.add(tokens[0]);
      else phrases.push(tokens);
    }

    return { wordSet, phrases };
  }

  function normalizePhraseToTokens(text) {
    const norm = normalizeWholeText(text).text;
    const out = [];
    const re = /[a-z0-9]+/g;
    let m;
    while ((m = re.exec(norm))) {
      out.push(collapseRepeats(m[0]));
    }
    return out;
  }

  function canonicalizeWord(word) {
    const norm = normalizeWholeText(word).text;
    const m = norm.match(/[a-z0-9]+/);
    return m ? collapseRepeats(m[0]) : '';
  }

  function collapseRepeats(str) {
    return str.replace(/(.)\1{2,}/g, '$1');
  }

  function normalizeWholeText(original) {
    const chars = [];
    const map = [];
    let lastSpace = true;

    for (let i = 0; i < original.length; i++) {
      const ch = original[i];

      if (/\s/.test(ch)) {
        if (!lastSpace) {
          chars.push(' ');
          map.push(i);
          lastSpace = true;
        }
        continue;
      }

      if (/[\u200B-\u200D\uFEFF]/.test(ch)) continue;

      const lowered = ch.toLowerCase();
      const stripped = lowered.normalize('NFD').replace(/[\u0300-\u036f]/g, '');

      for (const raw of stripped) {
        const c = CHAR_MAP[raw] || raw;
        if (/[a-z0-9]/.test(c)) {
          chars.push(c);
          map.push(i);
          lastSpace = false;
        } else {
          if (!lastSpace) {
            chars.push(' ');
            map.push(i);
            lastSpace = true;
          }
        }
      }
    }

    while (chars.length && chars[0] === ' ') {
      chars.shift();
      map.shift();
    }
    while (chars.length && chars[chars.length - 1] === ' ') {
      chars.pop();
      map.pop();
    }

    return { text: chars.join(''), map };
  }

  function bootstrap() {
    createButton();

    const mo = new MutationObserver(queueRefresh);
    mo.observe(document.documentElement || document.body, { childList: true, subtree: true });

    window.addEventListener('load', queueRefresh, true);
    window.addEventListener('resize', queueRefresh, true);
    window.addEventListener('scroll', queueRefresh, true);

    setInterval(queueRefresh, 500);
    queueRefresh();
  }

  function queueRefresh() {
    cancelAnimationFrame(rafId);
    rafId = requestAnimationFrame(refresh);
  }

  function refresh() {
    const input = findBestEditable();

    if (!input) {
      restoreInputAppearance(currentInput);
      currentInput = null;
      destroyMirror();
      return;
    }

    if (currentInput !== input) {
      restoreInputAppearance(currentInput);
      currentInput = input;
      installOnInput(input);
      console.log('[YTCWG] input attached:', describeElement(input));
    }

    if (!config.enabled) {
      restoreInputAppearance(input);
      destroyMirror();
      return;
    }

    const text = getInputText(input);

    if (!text) {
      restoreInputAppearance(input);
      destroyMirror();
      return;
    }

    const result = detectMatches(text);
    ensureMirror();
    forceInputTransparent(input);
    renderMirrorOverInput(input, text, result.ranges);
    input.style.outline = result.ranges.length ? '1px solid rgba(255, 90, 103, 0.65)' : '';
  }

  function describeElement(el) {
    if (!el) return 'null';
    return {
      tag: el.tagName,
      id: el.id || '',
      cls: el.className || '',
      role: el.getAttribute('role'),
      aria: el.getAttribute('aria-label'),
      placeholder: el.getAttribute('placeholder')
    };
  }

  function isVisible(el) {
    if (!el || !(el instanceof Element)) return false;
    const r = el.getBoundingClientRect();
    const s = getComputedStyle(el);
    return r.width > 0 && r.height > 0 && s.visibility !== 'hidden' && s.display !== 'none';
  }

  function isEditableCandidate(el) {
    if (!el || !(el instanceof Element)) return false;
    const tag = el.tagName?.toLowerCase();

    if (el.isContentEditable) return true;
    if (el.getAttribute('role') === 'textbox') return true;
    if (tag === 'textarea') return true;
    if (tag === 'input') {
      const type = (el.getAttribute('type') || 'text').toLowerCase();
      return ['text', 'search', 'email', 'url', 'tel', ''].includes(type);
    }
    return false;
  }

  function scoreCandidate(el) {
    let score = 0;
    const rect = el.getBoundingClientRect();
    const txt = [
      el.getAttribute('aria-label') || '',
      el.getAttribute('placeholder') || '',
      el.id || '',
      el.className || ''
    ].join(' ').toLowerCase();

    if (txt.includes('chat')) score += 50;
    if (txt.includes('message')) score += 40;
    if (txt.includes('send')) score += 10;
    if (el.isContentEditable) score += 10;
    if (rect.bottom > window.innerHeight * 0.45) score += 20;
    score += Math.min(20, Math.floor(rect.width * rect.height / 10000));

    let p = el;
    for (let i = 0; i < 8 && p; i++) {
      const tag = p.tagName?.toLowerCase() || '';
      if (tag.includes('yt-live-chat')) score += 25;
      p = p.parentElement || p.parentNode?.host || null;
    }

    return score;
  }

  function walkDeep(root, results, seen) {
    if (!root || seen.has(root)) return;
    seen.add(root);

    const children = root.children ? Array.from(root.children) : [];
    for (const el of children) {
      if (isEditableCandidate(el) && isVisible(el)) {
        results.push(el);
      }

      if (el.shadowRoot) {
        walkDeep(el.shadowRoot, results, seen);
      }

      if (el.tagName === 'IFRAME') {
        try {
          const doc = el.contentDocument || el.contentWindow?.document;
          if (doc) walkDeep(doc, results, seen);
        } catch (_) {}
      }

      walkDeep(el, results, seen);
    }
  }

  function deepestActiveElement(doc = document) {
    let el = doc.activeElement;
    while (el && el.shadowRoot && el.shadowRoot.activeElement) {
      el = el.shadowRoot.activeElement;
    }
    return el;
  }

  function findBestEditable() {
    const active = deepestActiveElement(document);
    if (active && isEditableCandidate(active) && isVisible(active)) {
      return active;
    }

    const results = [];
    walkDeep(document, results, new Set());

    if (!results.length) return null;

    results.sort((a, b) => scoreCandidate(b) - scoreCandidate(a));
    return results[0];
  }

  function installOnInput(input) {
    if (!input || input.dataset.ytcwgInstalled === '1') return;
    input.dataset.ytcwgInstalled = '1';

    input.addEventListener('compositionstart', () => composing = true, true);
    input.addEventListener('compositionend', () => {
      composing = false;
      queueRefresh();
    }, true);

    input.addEventListener('input', () => {
      if (!composing) queueRefresh();
    }, true);

    input.addEventListener('keyup', () => {
      if (!composing) queueRefresh();
