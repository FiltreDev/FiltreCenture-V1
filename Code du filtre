      : '#ffffff';
  }

  function restoreInputAppearance(input) {
    if (!input) return;
    if (input.dataset.ytcwgOrigColor !== undefined) input.style.color = input.dataset.ytcwgOrigColor;
    if (input.dataset.ytcwgOrigFill !== undefined) input.style.webkitTextFillColor = input.dataset.ytcwgOrigFill;
    if (input.dataset.ytcwgOrigCaret !== undefined) input.style.caretColor = input.dataset.ytcwgOrigCaret;
    if (input.dataset.ytcwgOrigShadow !== undefined) input.style.textShadow = input.dataset.ytcwgOrigShadow;
    input.style.outline = '';
  }

  function ensureMirror() {
    if (mirrorEl && document.contains(mirrorEl)) return;

    mirrorEl = document.createElement('div');
    mirrorEl.id = MIRROR_ID;
    mirrorEl.setAttribute('aria-hidden', 'true');
    document.documentElement.appendChild(mirrorEl);
  }

  function destroyMirror() {
    if (mirrorEl) {
      mirrorEl.remove();
      mirrorEl = null;
